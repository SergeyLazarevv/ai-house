# ai-house — скопируйте: cp .env.example .env

# LLM: yandex | anthropic | openai
LLM_PROVIDER=yandex

# Yandex (при LLM_PROVIDER=yandex)
YANDEX_API_KEY=
YANDEX_CATALOG_ID=
YANDEX_MODEL=yandexgpt-lite

# LLM supervisor: максимум шагов оркестратора до принудительного finish
GRAPH_SUPERVISOR_MAX_STEPS=10

# Флаги агентов (true/false)
AGENT_GENERAL_ENABLED=true
AGENT_LOGS_ENABLED=true
AGENT_DB_ENABLED=true
AGENT_CODE_ENABLED=true

# Graylog REST API, который использует локальный Graylog MCP server
# Базовый URL API (без /mcp): http://HOST:9000/api
GRAYLOG_URL=http://127.0.0.1:9000/api
# Personal Access Token (System → Users → Edit → Access tokens) или совместимость:
GRAYLOG_TOKEN=
# Альтернатива токену: GRAYLOG_USER= + GRAYLOG_PASSWORD=
# Самоподписанный HTTPS: GRAYLOG_VERIFY_SSL=false
# Заголовок X-Requested-By для Graylog REST (по умолчанию ai-house)
# GRAYLOG_X_REQUESTED_BY=ai-house
# Эти переменные читает отдельный MCP-процесс, а не сам HTTP API ai-house.

# Postgres MCP (агент БД). В Docker к хосту: host.docker.internal
POSTGRES_MCP_DSN=postgresql://user:password@host.docker.internal:5432/dbname

# GitLab (агент кода)
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=
